\@writefile{lot}{\contentsline {table}{\numberline {\relax Table\nobreakspace  {\relax 5}.4}{\ignorespaces Scaling with task graph size $n$. The theoretical PoA bound $(2-1/m)/(1-\ell ) = 1.67$ is independent of $n$; empirical PoA remains well below this bound across all scales. Exploitability increases modestly with $n$ (larger state space is harder to explore) but stays below the convergence threshold. Training time scales polynomially ($\approx O(n^{1.7})$).}}{56}{table.caption.19}\protected@file@percent }
\newlabel{tab:e5-tasks}{{\relax Table\nobreakspace  {\relax 5}.4}{56}{Scaling with task graph size $n$. The theoretical PoA bound $(2-1/m)/(1-\ell ) = 1.67$ is independent of $n$; empirical PoA remains well below this bound across all scales. Exploitability increases modestly with $n$ (larger state space is harder to explore) but stays below the convergence threshold. Training time scales polynomially ($\approx O(n^{1.7})$)}{table.caption.19}{}}
\@writefile{lot}{\contentsline {table}{\numberline {\relax Table\nobreakspace  {\relax 5}.5}{\ignorespaces Scaling with agent count $m$. The theoretical PoA bound increases with $m$ (market friction compounds), but absolute makespan decreases (more parallelism). MARL remains below the bound in all cases.}}{56}{table.caption.20}\protected@file@percent }
\newlabel{tab:e5-agents}{{\relax Table\nobreakspace  {\relax 5}.5}{56}{Scaling with agent count $m$. The theoretical PoA bound increases with $m$ (market friction compounds), but absolute makespan decreases (more parallelism). MARL remains below the bound in all cases}{table.caption.20}{}}

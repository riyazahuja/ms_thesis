\@writefile{lof}{\contentsline {figure}{\numberline {\relax Figure\nobreakspace  {\relax 5}.1}{\ignorespaces Publication externality (MATPG, dashed) vs.\ market internalization (MMATPG, solid) across dependency density $\rho $. Left: $\mathrm  {Pub\%}$ drops sharply under credit-based rewards as dependencies increase, while the market holds it near $100\%$. Middle: PoA grows unboundedly without the market; the market keeps it below $1.25$ regardless of $\rho $. Right: resolution rate collapses without the market at high $\rho $; the market maintains near-complete resolution throughout.}}{52}{figure.caption.11}\protected@file@percent }
\newlabel{fig:e2a}{{\relax Figure\nobreakspace  {\relax 5}.1}{52}{Publication externality (MATPG, dashed) vs.\ market internalization (MMATPG, solid) across dependency density $\rho $. Left: $\mathrm {Pub\%}$ drops sharply under credit-based rewards as dependencies increase, while the market holds it near $100\%$. Middle: PoA grows unboundedly without the market; the market keeps it below $1.25$ regardless of $\rho $. Right: resolution rate collapses without the market at high $\rho $; the market maintains near-complete resolution throughout}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {\relax Figure\nobreakspace  {\relax 5}.2}{\ignorespaces PoA as a function of loss parameter $\ell $. Empirical PoA (solid) lies below the theoretical bound $(2-1/m)/(1-\ell )$ (dashed) throughout, validating the $1/(1-\ell )$ friction factor. At $\ell =0$ the market is a pure bounty system; at $\ell =0.5$ market friction visibly increases equilibrium cost.}}{52}{figure.caption.12}\protected@file@percent }
\newlabel{fig:e2b}{{\relax Figure\nobreakspace  {\relax 5}.2}{52}{PoA as a function of loss parameter $\ell $. Empirical PoA (solid) lies below the theoretical bound $(2-1/m)/(1-\ell )$ (dashed) throughout, validating the $1/(1-\ell )$ friction factor. At $\ell =0$ the market is a pure bounty system; at $\ell =0.5$ market friction visibly increases equilibrium cost}{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {\relax Figure\nobreakspace  {\relax 5}.3}{\ignorespaces Training dynamics over population iterations. Left: exploitability tracks $O(1/\sqrt  {T})$ reference. Middle: PoA converges toward the theoretical bound of $1.67$. Right: entropy annealing avoids premature convergence.}}{53}{figure.caption.13}\protected@file@percent }
\newlabel{fig:e3-training}{{\relax Figure\nobreakspace  {\relax 5}.3}{53}{Training dynamics over population iterations. Left: exploitability tracks $O(1/\sqrt {T})$ reference. Middle: PoA converges toward the theoretical bound of $1.67$. Right: entropy annealing avoids premature convergence}{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {\relax Figure\nobreakspace  {\relax 5}.4}{\ignorespaces Rollout behavior statistics over PSRO training. Publication rate rises as agents internalize market incentives; market participation overshoots then stabilizes as trading becomes more deliberate; idle rate falls as agents learn productive task sequences. Together these confirm that the market externality is being learned away, not just suppressed.}}{53}{figure.caption.14}\protected@file@percent }
\newlabel{fig:e3-behavior}{{\relax Figure\nobreakspace  {\relax 5}.4}{53}{Rollout behavior statistics over PSRO training. Publication rate rises as agents internalize market incentives; market participation overshoots then stabilizes as trading becomes more deliberate; idle rate falls as agents learn productive task sequences. Together these confirm that the market externality is being learned away, not just suppressed}{figure.caption.14}{}}
\@writefile{lot}{\contentsline {table}{\numberline {\relax Table\nobreakspace  {\relax 5}.2}{\ignorespaces Policy comparison at convergence ($n=8$, $m=2$, $d=3$, $\ell =0.1$). Theoretical MMATPG PoA bound: $(2-1/m)/(1-\ell ) = 1.67$. MARL achieves bounded PoA and high resolution, substantially improving over the no-market greedy baseline. RLS provides the centralized optimum reference.}}{53}{table.caption.17}\protected@file@percent }
\newlabel{tab:e3b}{{\relax Table\nobreakspace  {\relax 5}.2}{53}{Policy comparison at convergence ($n=8$, $m=2$, $d=3$, $\ell =0.1$). Theoretical MMATPG PoA bound: $(2-1/m)/(1-\ell ) = 1.67$. MARL achieves bounded PoA and high resolution, substantially improving over the no-market greedy baseline. RLS provides the centralized optimum reference}{table.caption.17}{}}
